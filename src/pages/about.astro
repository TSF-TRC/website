---
import Base from "~/layouts/Base.astro";
import { coChairs, members } from "~/data/members";
import { site } from "~/data/site";
---

<Base
  title="About"
  description="The Tooling Research Committee is a research committee of the Trust & Safety Foundation, made up of researchers, practitioners, and engineers advancing the tools that protect online communities."
>
  <article class="about">
    <header class="about__hero container">
      <span class="eyebrow">About the committee</span>
      <h1 class="about__title">
        Researchers and practitioners,<br />
        publishing the field's <em>shared infrastructure</em>.
      </h1>
      <p class="lede about__lede">
        The Tooling Research Committee (TRC) is a research committee of the
        <a href={site.parent.url} rel="noopener">{site.parent.name}</a>.
        We bring together researchers, practitioners, and engineers from industry, academia,
        and civil society to advance online safety through collaborative research on the
        tools that protect digital communities.
      </p>
    </header>

    <section class="about__principles container">
      <div class="principles-grid">
        <div class="principle">
          <span class="principle__num">i.</span>
          <h3 class="principle__title">Discoverable</h3>
          <p>Research and outputs are designed to be findable and applicable by the people
          doing the work — published with the policies, methodology, and context practitioners
          need to put them to use.</p>
        </div>
        <div class="principle">
          <span class="principle__num">ii.</span>
          <h3 class="principle__title">Cross-sector</h3>
          <p>Members come from product teams, research labs, NGOs, and policy
          institutions — work is shaped by people who build, study, and regulate
          platforms.</p>
        </div>
        <div class="principle">
          <span class="principle__num">iii.</span>
          <h3 class="principle__title">Useful first</h3>
          <p>The committee scopes its work to outputs practitioners will actually adopt,
          not artifacts that sit unread.</p>
        </div>
      </div>
    </section>

    <section class="about__people container">
      <header class="people-header">
        <span class="eyebrow">Co-chairs</span>
        <h2>Leadership</h2>
      </header>
      <ul class="cochair-list">
        {coChairs.map((p) => (
          <li class="cochair">
            <span class="cochair__name">{p.name}</span>
            <span class="cochair__role">Co-chair</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="about__members container">
      <header class="people-header">
        <span class="eyebrow">Committee · {members.length} members</span>
        <h2>Members</h2>
      </header>
      <ul class="members-grid">
        {members.map((m) => (
          <li class="member">{m.name}</li>
        ))}
      </ul>
      <p class="about__footnote">
        Full membership and biographies are maintained on the
        <a href={site.parent.parentPageUrl} rel="noopener">parent committee page at the {site.parent.shortName} ↗</a>.
      </p>
    </section>
  </article>
</Base>

<style>
  .about__hero {
    padding-block: var(--space-9) var(--space-8);
    max-width: var(--measure-wide);
  }

  .about__title {
    margin-top: var(--space-3);
    font-size: var(--step-6);
    line-height: 1.02;
    letter-spacing: -0.025em;
    max-width: 22ch;
  }

  .about__title em {
    font-style: italic;
    font-weight: 380;
    font-variation-settings: "opsz" 144, "SOFT" 100;
    color: var(--accent-deep);
  }

  .about__lede {
    margin-top: var(--space-5);
    max-width: 44rem;
  }

  /* Principles */
  .about__principles {
    padding-block: var(--space-7) var(--space-9);
    border-top: 1px solid var(--rule);
  }

  .principles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-7);
  }

  .principle__num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-2);
    color: var(--accent);
    font-variation-settings: "opsz" 36, "SOFT" 100;
  }

  .principle__title {
    margin-top: var(--space-3);
    font-size: var(--step-1);
    font-weight: 520;
    font-variation-settings: "opsz" 24;
  }

  .principle p {
    margin-top: var(--space-3);
    color: var(--ink-soft);
    font-size: var(--step-0);
    line-height: 1.55;
    max-width: 32ch;
  }

  @media (max-width: 820px) {
    .principles-grid { grid-template-columns: 1fr; gap: var(--space-6); }
    .principle p { max-width: none; }
  }

  /* People */
  .about__people, .about__members {
    padding-block: var(--space-7);
    border-top: 1px solid var(--rule);
  }

  .people-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .people-header h2 {
    font-size: var(--step-4);
  }

  .cochair-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
  }

  .cochair {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5);
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-md);
  }

  .cochair__name {
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 460;
    letter-spacing: -0.01em;
    font-variation-settings: "opsz" 36, "SOFT" 30;
    color: var(--ink);
  }

  .cochair__role {
    font-size: var(--step--1);
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  @media (max-width: 640px) {
    .cochair-list { grid-template-columns: 1fr; }
  }

  .members-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(14rem, 1fr));
    gap: 0;
    border-top: 1px solid var(--rule-soft);
  }

  .member {
    padding: var(--space-4) var(--space-2);
    border-bottom: 1px solid var(--rule-soft);
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 430;
    color: var(--ink);
    font-variation-settings: "opsz" 24, "SOFT" 30;
    letter-spacing: -0.005em;
  }

  .about__footnote {
    margin-top: var(--space-6);
    color: var(--muted);
    font-size: var(--step--1);
  }
</style>
