---
import Base from "~/layouts/Base.astro";
import WorkstreamHero from "~/components/WorkstreamHero.astro";
import { workstreamBySlug } from "~/data/workstreams";
import { site } from "~/data/site";

const workstream = workstreamBySlug("maturity-model")!;

const stages = [
  {
    name: "Seed",
    headcount: "<10",
    risk: "Founder-led moderation, ad-hoc tools",
    focus: "Define acceptable use; build minimum reporting + takedown path.",
  },
  {
    name: "Early",
    headcount: "10–50",
    risk: "First abusive growth patterns",
    focus: "Lightweight automation; on-call rotation; incident logs.",
  },
  {
    name: "Growth",
    headcount: "50–500",
    risk: "Coordinated abuse, regulator awareness",
    focus: "Specialized T&S team; classifier pipeline; transparency reporting.",
  },
  {
    name: "Scale",
    headcount: "500–5,000",
    risk: "Cross-jurisdictional obligations, novel harms",
    focus: "Policy operations; appeals; red team; cross-platform signals.",
  },
  {
    name: "Mature",
    headcount: "5,000+",
    risk: "Systemic impact, public scrutiny",
    focus: "Research function; external audits; cross-industry coordination.",
  },
];
---

<Base
  title={workstream.shortTitle}
  description={workstream.description}
>
  <WorkstreamHero workstream={workstream} status="Forming · Inaugural year" />

  <section class="container mm-prelude">
    <div class="mm-prelude__grid">
      <div class="mm-prelude__lead">
        <h2>The shape of the model</h2>
        <p>
          Teams that get safety right tend to invest in the same kinds of
          infrastructure in roughly the same order — but the order is mostly
          folklore, and few teams have the benchmarks to know when to invest
          ahead of the curve. This workstream maps that progression into a
          public model that platforms can use to plan.
        </p>
      </div>
      <div class="mm-prelude__pull">
        <span class="eyebrow">A working definition</span>
        <blockquote>
          A maturity model for trust &amp; safety isn't a checklist —
          it's a description of which capabilities tend to keep the
          next failure from happening.
        </blockquote>
      </div>
    </div>
  </section>

  <section class="container mm-stages">
    <header class="mm-stages__header">
      <span class="eyebrow">Sketch · Subject to revision</span>
      <h2>Proposed stages</h2>
      <p>
        A first sketch of the stages we expect the model to cover, with the
        characteristic risks and investments at each. Final stage definitions
        will emerge from expert interviews and industry benchmarking.
      </p>
    </header>

    <ol class="stages">
      {stages.map((s, i) => (
        <li class="stage">
          <div class="stage__num">
            <span class="stage__index">{String(i + 1).padStart(2, "0")}</span>
          </div>
          <div class="stage__body">
            <h3 class="stage__name">{s.name}</h3>
            <dl class="stage__facts">
              <div>
                <dt>Org size</dt>
                <dd>{s.headcount}</dd>
              </div>
              <div>
                <dt>Dominant risk</dt>
                <dd>{s.risk}</dd>
              </div>
              <div>
                <dt>Focus</dt>
                <dd>{s.focus}</dd>
              </div>
            </dl>
          </div>
        </li>
      ))}
    </ol>
  </section>

  <section class="container mm-outputs">
    <div class="mm-outputs__grid">
      <div>
        <span class="eyebrow">Expected outputs</span>
        <h2>What this workstream will produce</h2>
        <ul class="mm-outputs__list">
          <li>A staged maturity framework with capability checklists</li>
          <li>Industry benchmarking data behind each stage</li>
          <li>A self-assessment teams can run against the model</li>
          <li>A reference reading list for each stage's investments</li>
        </ul>
      </div>
      <div class="mm-outputs__cta">
        <span class="eyebrow">Get involved</span>
        <p>
          The committee is recruiting practitioners to share their team's
          history at each stage. Membership and contact paths are handled
          through the parent committee page.
        </p>
        <a class="mm-outputs__link" href={site.parent.parentPageUrl} rel="noopener">
          Visit the {site.parent.shortName} page
          <svg width="14" height="10" viewBox="0 0 14 10" aria-hidden="true">
            <path d="M1 5H13M13 5L9 1M13 5L9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  /* Prelude */
  .mm-prelude {
    padding-block: var(--space-8) var(--space-7);
  }
  .mm-prelude__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: var(--space-7);
    align-items: start;
  }
  .mm-prelude__lead h2 {
    font-size: var(--step-3);
    margin-bottom: var(--space-4);
  }
  .mm-prelude__lead p {
    color: var(--ink-soft);
    font-size: var(--step-0);
    line-height: 1.65;
    max-width: 36rem;
  }
  .mm-prelude__pull blockquote {
    margin-top: var(--space-3);
    border-left: 2px solid var(--accent);
    padding-left: var(--space-4);
    font-family: var(--font-display);
    font-size: var(--step-2);
    font-weight: 380;
    line-height: 1.32;
    font-variation-settings: "opsz" 36, "SOFT" 100;
    color: var(--ink);
  }
  @media (max-width: 880px) {
    .mm-prelude__grid { grid-template-columns: 1fr; }
  }

  /* Stages */
  .mm-stages {
    padding-block: var(--space-7) var(--space-8);
    border-top: 1px solid var(--rule);
  }
  .mm-stages__header {
    margin-bottom: var(--space-7);
    max-width: 44rem;
  }
  .mm-stages__header h2 {
    margin-top: var(--space-2);
    font-size: var(--step-4);
  }
  .mm-stages__header p {
    margin-top: var(--space-4);
    color: var(--ink-soft);
    max-width: 38rem;
    line-height: 1.6;
  }

  .stages {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .stage {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: var(--space-6);
    padding-block: var(--space-6);
    border-top: 1px solid var(--rule-soft);
  }
  .stage:last-child {
    border-bottom: 1px solid var(--rule-soft);
  }

  .stage__num {
    display: flex;
    align-items: flex-start;
    justify-content: flex-start;
  }
  .stage__index {
    font-family: var(--font-display);
    font-size: var(--step-4);
    font-style: italic;
    font-weight: 380;
    color: var(--accent);
    font-variation-settings: "opsz" 60, "SOFT" 100;
    line-height: 1;
  }

  .stage__name {
    font-size: var(--step-2);
    font-weight: 460;
    margin-bottom: var(--space-3);
    font-variation-settings: "opsz" 36;
  }

  .stage__facts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4);
    margin: 0;
  }
  .stage__facts dt {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: var(--space-1);
    font-weight: 540;
  }
  .stage__facts dd {
    margin: 0;
    font-size: var(--step--1);
    color: var(--ink-soft);
    line-height: 1.5;
  }

  @media (max-width: 720px) {
    .stage { grid-template-columns: 1fr; gap: var(--space-3); }
    .stage__facts { grid-template-columns: 1fr; gap: var(--space-3); }
  }

  /* Outputs */
  .mm-outputs {
    padding-block: var(--space-8) var(--space-9);
    border-top: 1px solid var(--rule);
  }
  .mm-outputs__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-8);
    align-items: start;
  }
  .mm-outputs__grid h2 {
    font-size: var(--step-3);
    margin-top: var(--space-3);
  }
  .mm-outputs__list {
    margin-top: var(--space-4);
    padding-left: 1.2rem;
    color: var(--ink-soft);
    line-height: 1.65;
  }
  .mm-outputs__list li + li { margin-top: var(--space-2); }

  .mm-outputs__cta {
    padding: var(--space-6);
    background: var(--accent-tint);
    border-radius: var(--radius-md);
    border: 1px solid var(--accent-soft);
  }
  .mm-outputs__cta p {
    margin-top: var(--space-3);
    color: var(--ink-soft);
    font-size: var(--step--1);
    line-height: 1.55;
  }
  .mm-outputs__link {
    margin-top: var(--space-5);
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-weight: 540;
    color: var(--accent-deep);
    font-size: var(--step--1);
  }
  .mm-outputs__link:hover svg { transform: translateX(3px); }
  .mm-outputs__link svg { transition: transform 200ms var(--ease); }

  @media (max-width: 820px) {
    .mm-outputs__grid { grid-template-columns: 1fr; }
  }
</style>
