---
import { site } from "~/data/site";
import { workstreams } from "~/data/workstreams";

type Props = { pathname: string };
const { pathname } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const isActive = (href: string) => {
  const p = pathname.replace(base, "").replace(/\/$/, "") || "/";
  if (href === "/") return p === "/";
  return p === href || p.startsWith(href + "/");
};

const workstreamsActive = isActive("/workstreams");
const aboutActive = isActive("/about");
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="wordmark" href={`${base}/`} aria-label={`${site.name} home`}>
      <span class="wordmark__eyebrow">{site.parent.shortName}</span>
      <span class="wordmark__name">Tooling Research<br />Committee</span>
    </a>

    <nav class="primary-nav" aria-label="Primary">
      <ul>
        <li class="nav-menu" data-nav-menu>
          <button
            type="button"
            class="nav-menu__trigger"
            aria-haspopup="menu"
            aria-expanded="false"
            aria-controls="about-menu"
            aria-current={aboutActive ? "page" : undefined}
            data-nav-trigger
          >
            <span>About</span>
            <svg class="nav-menu__chevron" width="10" height="6" viewBox="0 0 10 6" aria-hidden="true">
              <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none" />
            </svg>
          </button>
          <div class="nav-menu__panel nav-menu__panel--narrow" role="menu" id="about-menu" aria-label="About">
            <a
              class="nav-menu__overview"
              href={`${base}/about`}
              role="menuitem"
            >
              <span class="nav-menu__overview-label">About the committee</span>
              <span class="nav-menu__overview-note">Mission and goals →</span>
            </a>
            <ul class="nav-menu__list">
              <li>
                <a
                  href={`${base}/about#members`}
                  role="menuitem"
                  class="nav-menu__item nav-menu__item--simple"
                >
                  <span class="nav-menu__item-body">
                    <span class="nav-menu__item-title">Members</span>
                    <span class="nav-menu__item-tag">Co-chairs and the full committee roster</span>
                  </span>
                </a>
              </li>
            </ul>
          </div>
        </li>

        <li class="nav-menu" data-nav-menu>
          <button
            type="button"
            class="nav-menu__trigger"
            aria-haspopup="menu"
            aria-expanded="false"
            aria-controls="workstreams-menu"
            aria-current={workstreamsActive ? "page" : undefined}
            data-nav-trigger
          >
            <span>Workstreams</span>
            <svg class="nav-menu__chevron" width="10" height="6" viewBox="0 0 10 6" aria-hidden="true">
              <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none" />
            </svg>
          </button>
          <div class="nav-menu__panel" role="menu" id="workstreams-menu" aria-label="Workstreams">
            <a
              class="nav-menu__overview"
              href={`${base}/workstreams`}
              role="menuitem"
            >
              <span class="nav-menu__overview-label">All workstreams</span>
              <span class="nav-menu__overview-note">See the three projects together →</span>
            </a>
            <ul class="nav-menu__list">
              {workstreams.map((w) => (
                <li>
                  <a
                    href={`${base}/workstreams/${w.slug}`}
                    role="menuitem"
                    class="nav-menu__item"
                    aria-current={isActive(`/workstreams/${w.slug}`) ? "page" : undefined}
                  >
                    <span class="nav-menu__num">{w.number}</span>
                    <span class="nav-menu__item-body">
                      <span class="nav-menu__item-title">{w.shortTitle}</span>
                      <span class="nav-menu__item-tag">{w.tagline}</span>
                    </span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </li>

        <li>
          <a
            class="external"
            href={site.parent.url}
            rel="noopener"
          >
            <span>{site.parent.name}</span>
            <svg width="11" height="11" viewBox="0 0 11 11" aria-hidden="true">
              <path d="M2 9L9 2M9 2H3.5M9 2V7.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" fill="none" />
            </svg>
          </a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  // Nav-bar dropdowns — click/keyboard toggle, hover handled in CSS.
  // Each `[data-nav-menu]` is an independent disclosure; opening one closes
  // any others that happen to be open.
  const menus = document.querySelectorAll<HTMLElement>("[data-nav-menu]");

  menus.forEach((root) => {
    const trigger = root.querySelector<HTMLButtonElement>("[data-nav-trigger]");
    const panel = root.querySelector<HTMLElement>(".nav-menu__panel");
    if (!trigger || !panel) return;

    const closeOthers = () => {
      menus.forEach((other) => {
        if (other === root) return;
        other.querySelector<HTMLButtonElement>("[data-nav-trigger]")?.setAttribute(
          "aria-expanded",
          "false",
        );
        delete (other as HTMLElement).dataset.open;
      });
    };

    const open = () => {
      closeOthers();
      trigger.setAttribute("aria-expanded", "true");
      root.dataset.open = "true";
    };
    const close = () => {
      trigger.setAttribute("aria-expanded", "false");
      delete root.dataset.open;
    };
    const toggle = () => {
      trigger.getAttribute("aria-expanded") === "true" ? close() : open();
    };

    trigger.addEventListener("click", (e) => {
      e.preventDefault();
      toggle();
    });

    trigger.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown" || e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        open();
        const first = panel.querySelector<HTMLElement>("a[role='menuitem']");
        first?.focus();
      }
    });

    panel.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        close();
        trigger.focus();
      }
    });
  });

  // Outside-click and outside-focus close any open menu.
  const isInsideAny = (target: Node | null) => {
    if (!target) return false;
    return Array.from(menus).some((m) => m.contains(target));
  };
  document.addEventListener("click", (e) => {
    if (!isInsideAny(e.target as Node)) {
      menus.forEach((m) => {
        m.querySelector<HTMLButtonElement>("[data-nav-trigger]")?.setAttribute(
          "aria-expanded",
          "false",
        );
        delete (m as HTMLElement).dataset.open;
      });
    }
  });
  document.addEventListener("focusin", (e) => {
    if (!isInsideAny(e.target as Node)) {
      menus.forEach((m) => {
        m.querySelector<HTMLButtonElement>("[data-nav-trigger]")?.setAttribute(
          "aria-expanded",
          "false",
        );
        delete (m as HTMLElement).dataset.open;
      });
    }
  });
</script>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: var(--paper);
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: saturate(140%) blur(8px);
    background: color-mix(in oklab, var(--paper) 92%, transparent);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-6);
    padding-block: var(--space-4);
    min-height: 5rem;
  }

  .wordmark {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    color: var(--ink);
    text-decoration: none;
    line-height: 1;
  }

  .wordmark:hover { color: var(--accent-deep); }

  .wordmark__eyebrow {
    font-family: var(--font-body);
    font-size: 0.68rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 540;
  }

  .wordmark__name {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: -0.005em;
    line-height: 1.1;
    font-variation-settings: "opsz" 14, "SOFT" 30;
  }

  .primary-nav > ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin: 0;
    padding: 0;
  }

  .primary-nav > ul > li > a,
  .nav-menu__trigger {
    font-size: var(--step--1);
    font-weight: 480;
    color: var(--ink-soft);
    text-decoration: none;
    padding-block: var(--space-2);
    position: relative;
    background: none;
    border: 0;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: inherit;
  }

  .primary-nav > ul > li > a:hover,
  .nav-menu__trigger:hover { color: var(--accent-deep); }

  .primary-nav > ul > li > a[aria-current="page"],
  .nav-menu__trigger[aria-current="page"] {
    color: var(--ink);
  }

  .primary-nav > ul > li > a[aria-current="page"]::after,
  .nav-menu__trigger[aria-current="page"]::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: var(--accent);
  }

  .primary-nav > ul > li > a.external {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    color: var(--muted);
  }

  .primary-nav > ul > li > a.external:hover { color: var(--accent-deep); }
  .primary-nav > ul > li > a.external svg { opacity: 0.7; }

  /* Dropdown menu */
  .nav-menu {
    position: relative;
  }

  .nav-menu__trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
  }

  .nav-menu__chevron {
    transition: transform 220ms var(--ease);
    margin-top: 1px;
  }

  .nav-menu[data-open] .nav-menu__chevron,
  .nav-menu:hover .nav-menu__chevron,
  .nav-menu:focus-within .nav-menu__chevron {
    transform: rotate(180deg);
  }

  .nav-menu__panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%) translateY(-4px);
    width: 22rem;
    max-width: calc(100vw - 2rem);
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-md);
    box-shadow: 0 24px 60px -28px rgba(28, 27, 23, 0.35), 0 2px 8px -4px rgba(28, 27, 23, 0.08);
    padding: var(--space-3);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 180ms var(--ease), transform 220ms var(--ease), visibility 180ms;
    z-index: 60;
  }

  .nav-menu__panel--narrow {
    width: 18rem;
  }

  .nav-menu:hover .nav-menu__panel,
  .nav-menu:focus-within .nav-menu__panel,
  .nav-menu[data-open] .nav-menu__panel {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  /* Hover bridge so cursor can move from trigger to panel without closing */
  .nav-menu::before {
    content: "";
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    height: 0.6rem;
  }

  .nav-menu__overview {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-sm);
    background: var(--accent-tint);
    text-decoration: none;
    color: var(--ink);
    margin-bottom: var(--space-2);
    transition: background 180ms var(--ease);
  }

  .nav-menu__overview:hover {
    background: var(--accent-soft);
    text-decoration: none;
  }

  .nav-menu__overview-label {
    font-family: var(--font-display);
    font-size: var(--step-0);
    font-weight: 500;
    color: var(--ink);
    font-variation-settings: "opsz" 24, "SOFT" 30;
  }

  .nav-menu__overview-note {
    font-size: 0.78rem;
    color: var(--accent-deep);
  }

  .nav-menu__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: block;
  }

  .nav-menu__list li {
    display: block;
  }

  .nav-menu__item {
    display: grid;
    grid-template-columns: 2rem 1fr;
    gap: var(--space-3);
    align-items: baseline;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: var(--ink);
    transition: background 160ms var(--ease);
  }

  .nav-menu__item--simple {
    grid-template-columns: 1fr;
  }

  .nav-menu__item:hover,
  .nav-menu__item:focus-visible {
    background: var(--paper-soft);
    text-decoration: none;
  }

  .nav-menu__item[aria-current="page"] {
    background: var(--paper-soft);
  }

  .nav-menu__num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--step-1);
    font-weight: 420;
    color: var(--accent);
    font-variation-settings: "opsz" 24, "SOFT" 100;
    line-height: 1;
  }

  .nav-menu__item-body {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .nav-menu__item-title {
    font-family: var(--font-display);
    font-size: var(--step-0);
    font-weight: 500;
    color: var(--ink);
    line-height: 1.2;
    font-variation-settings: "opsz" 24, "SOFT" 30;
  }

  .nav-menu__item-tag {
    font-size: 0.78rem;
    color: var(--muted);
    line-height: 1.4;
  }

  @media (max-width: 640px) {
    .site-header__inner {
      flex-wrap: wrap;
      gap: var(--space-4);
    }
    .primary-nav ul { gap: var(--space-4); }
    .primary-nav a.external span { display: none; }

    .nav-menu__panel {
      width: min(20rem, calc(100vw - 2rem));
      left: auto;
      right: 0;
      transform: translateY(-4px);
    }

    .nav-menu:hover .nav-menu__panel,
    .nav-menu:focus-within .nav-menu__panel,
    .nav-menu[data-open] .nav-menu__panel {
      transform: translateY(0);
    }
  }
</style>
