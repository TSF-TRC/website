---
import type { Workstream } from "~/data/workstreams";

type Props = { workstream: Workstream };
const { workstream: w } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<a class="wcard" href={`${base}/workstreams/${w.slug}`}>
  <div class="wcard__head">
    <span class="wcard__num">{w.number}</span>
    <span class="wcard__rule" aria-hidden="true"></span>
    <span class="wcard__kicker">Workstream</span>
  </div>
  <h3 class="wcard__title">{w.title}</h3>
  <p class="wcard__tag">{w.tagline}</p>
  <span class="wcard__cta" aria-hidden="true">
    Read more
    <svg width="14" height="10" viewBox="0 0 14 10"><path d="M1 5H13M13 5L9 1M13 5L9 9" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" fill="none" /></svg>
  </span>
</a>

<style>
  .wcard {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-6);
    background: var(--surface);
    border: 1px solid var(--rule);
    border-radius: var(--radius-md);
    color: var(--ink);
    text-decoration: none;
    transition: transform 300ms var(--ease), border-color 300ms var(--ease), box-shadow 300ms var(--ease);
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .wcard::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(160deg, var(--accent-tint) 0%, transparent 60%);
    opacity: 0;
    transition: opacity 350ms var(--ease);
    z-index: -1;
  }

  .wcard:hover {
    transform: translateY(-2px);
    border-color: var(--accent-soft);
    box-shadow: 0 12px 30px -16px rgba(45, 90, 74, 0.25);
    text-decoration: none;
  }

  .wcard:hover::before { opacity: 1; }

  .wcard__head {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--muted);
  }

  .wcard__num {
    font-family: var(--font-display);
    font-size: var(--step-1);
    font-weight: 460;
    color: var(--accent);
    font-variation-settings: "opsz" 144, "SOFT" 30;
    letter-spacing: 0.02em;
  }

  .wcard__rule {
    flex: 1;
    height: 1px;
    background: var(--rule);
    max-width: 4rem;
  }

  .wcard__kicker {
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-weight: 540;
  }

  .wcard__title {
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 460;
    line-height: 1.12;
    letter-spacing: -0.015em;
    font-variation-settings: "opsz" 60, "SOFT" 30;
    color: var(--ink);
    margin: 0;
  }

  .wcard__tag {
    color: var(--ink-soft);
    font-size: var(--step-0);
    line-height: 1.5;
    max-width: 38ch;
    margin: 0;
  }

  .wcard__cta {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: var(--step--1);
    font-weight: 540;
    color: var(--accent);
    letter-spacing: 0.01em;
  }

  .wcard:hover .wcard__cta svg {
    transform: translateX(3px);
  }

  .wcard__cta svg {
    transition: transform 250ms var(--ease);
  }
</style>
